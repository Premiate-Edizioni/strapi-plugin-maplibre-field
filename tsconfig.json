{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["jest", "@testing-library/jest-dom"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["./admin/src/**/*", "./server/src/**/*", "./tests/**/*"],
  "exclude": ["node_modules", "dist", "build", ".cache"]
}
